BEGIN:VEVENT
SUMMARY:Equinox Studios Open House
LOCATION:6555 5th Avenue South\, Seattle
DTSTART;TZID=America/Los_Angeles:20350414T180000
DTEND;TZID=America/Los_Angeles:20350414T210000
X-MICROSOFT-CDO-ALLDAYEVENT:FALSE
