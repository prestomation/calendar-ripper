LOCATION:12th Avenue Arts\, <br>1620 12th Avenue\, Seattle\, Washington
 \, 98122
DTSTART;TZID=America/Los_Angeles:20260614T200000
DTEND;TZID=America/Los_Angeles:20260614T213000
