BEGIN:VEVENT
SUMMARY:2026 P Patch - Earth Day Resource Fair!
LOCATION:Northwest African American Museum @ 2300 S Massachusetts St\, S
 eattle\, WA\, 98144
DTSTART;TZID=America/Los_Angeles:20260425T100000
DTEND;TZID=America/Los_Angeles:20260425T130000
X-MICROSOFT-CDO-ALLDAYEVENT:FALSE
