 //washington.zoom.us/j/96677954374
X-TRUMBA-CUSTOMFIELD;NAME="Campus room";ID=28429;TYPE=SingleLine:D-209 T
 urner Auditorium
X-TRUMBA-CUSTOMFIELD;NAME="Accessibility Contact";ID=62969;TYPE=SingleLi
 ne:hsbuild@uw.edu
