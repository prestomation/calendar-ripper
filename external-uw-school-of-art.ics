X-TRUMBA-CUSTOMFIELD;NAME="Event interval";ID=30051;TYPE=CustomAsset:Sin
 gle day event
X-TRUMBA-CUSTOMFIELD;NAME="Online Meeting Link";ID=54756;TYPE=Url:<a hre
 f="https://washington.zoom.us/meeting/register/tFVftGpFSHakAb2JlDqxkA" t
