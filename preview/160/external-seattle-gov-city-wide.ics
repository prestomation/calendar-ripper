DTEND;TZID=America/Los_Angeles:20260415T210000
X-MICROSOFT-CDO-ALLDAYEVENT:FALSE
URL:https://townhallseattle.org/event/this-art-here/
X-TRUMBA-CUSTOMFIELD;NAME="Event Type";ID=21;TYPE=number:Arts and Cultur
 al Affairs Submission Form Template
X-TRUMBA-CUSTOMFIELD;NAME="Event Types";ID=11444;TYPE=CustomAsset:Arts\,
 Community\,Special Events
X-TRUMBA-CUSTOMFIELD;NAME="Neighborhoods";ID=11388;TYPE=CustomAsset:City
 wide\,Pioneer Square
